{
  "name": "smart-brief",
  "productName": "Smart Brief",
  "version": "1.1.0",
  "description": "Local-first visual brief creation tool for turning screenshots into clear visual instructions.",
  "main": "dist/main/main.cjs",
  "author": "Smart Brief",
  "license": "MIT",
  "private": true,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --max-warnings 0",
    "build:renderer": "vite build",
    "build:main": "node scripts/build-main.mjs",
    "build": "npm run typecheck && npm run build:renderer && npm run build:main",
    "start": "electron .",
    "dev": "node scripts/dev.mjs",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "package": "npm run build && electron-builder --mac --config electron-builder.yml",
    "package:signed": "npm run build && electron-builder --mac --config electron-builder.signed.yml",
    "package:dev-signed": "npm run build && electron-builder --mac --config electron-builder.selfsigned.yml"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0",
    "eslint": "^9.16.0",
    "fflate": "^0.8.3",
    "konva": "^9.3.16",
    "playwright": "^1.49.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-konva": "^18.2.10",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.17.0",
    "vite": "^6.0.3",
    "vitest": "^2.1.8",
    "zustand": "^5.0.2"
  }
}
