<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!--
      Entitlements for the FREE self-signed build (npm run package:dev-signed).

      A self-signed certificate carries no Team ID. On Apple Silicon, dyld's
      library validation then refuses to let the app load its own Electron
      Framework ("mapping process and mapped file have different Team IDs"), so
      it must be switched off explicitly for this signing mode.
    -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Required for Electron (V8 JIT). -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
  </dict>
</plist>
